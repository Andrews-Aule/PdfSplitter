# ── File necessari per usare l'app (NON ignorati) ──────────────────────────
# pdf_splitter.py      → sorgente principale
# pdf_splitter.svg     → icona sorgente
# pdf_splitter.desktop → collegamento per il menu GNOME
# assets/              → icone PNG precompilate per il binario
# README.md

# ── Residui Node.js (non servono) ──────────────────────────────────────────
node_modules/
package.json
package-lock.json

# ── Ambiente virtuale Python ────────────────────────────────────────────────
.venv/

# ── Claude Code ─────────────────────────────────────────────────────────────
.claude/

# ── Artefatti di build PyInstaller ──────────────────────────────────────────
build/
dist/
*.spec

# ── Cache Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── File temporanei ──────────────────────────────────────────────────────────
*.tmp
*.log
.DS_Store
